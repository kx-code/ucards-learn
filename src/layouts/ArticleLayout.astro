---
import SEOHead from '../components/SEOHead.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import CTASection from '../components/CTASection.astro'
import RelatedPosts from '../components/RelatedPosts.astro'
import Footer from '../components/Footer.astro'
import FAQ from '../components/FAQ.astro'
	import ArticleEnhancements from '../components/ArticleEnhancements.astro'
	import { articleJsonLd } from '../lib/seo'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  keywords?: string
  slug: string
  lang: 'zh' | 'en'
  date: Date
  updated: Date
  image?: string
  related?: string[]
  cta?: {
    title: string
    subtitle: string
  }
  category: string
  faqs?: Array<{ question: string; answer: string }>
  schemaType?: 'article' | 'howto' | 'glossary' | 'product'
}

const { title, description, keywords, slug, lang, date, updated, image, related, cta, category, faqs = [], schemaType = 'article' } = Astro.props

const langPath = lang === 'en' ? `/en/${slug}` : `/${slug}`
const jsonLd = articleJsonLd({
  title,
  description,
  url: `https://ucards.uk/learn${langPath}`,
  image,
  datePublished: date.toISOString(),
  dateModified: updated.toISOString(),
})

const breadcrumbItems = [
  { name: 'Learn', url: lang === 'en' ? 'https://ucards.uk/learn/en/' : 'https://ucards.uk/learn/' },
  { name: title, url: `https://ucards.uk/learn${langPath}` },
]
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead
      title={title}
      description={description}
      keywords={keywords}
      path={langPath}
      image={image}
      lang={lang}
      datePublished={date.toISOString()}
      dateModified={updated.toISOString()}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <header class="border-b border-gray-100">
      <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={lang === 'en' ? '/learn/en/' : '/learn/'} class="text-xl font-bold text-blue-600">
          uCards <span class="text-gray-400 font-normal text-base">Learn</span>
        </a>
        <nav class="flex gap-4 text-sm">
          <a href={lang === 'en' ? '/learn/en/' : '/learn/'} class="text-gray-600 hover:text-blue-600 transition-colors">
            {lang === 'en' ? 'All Articles' : '所有文章'}
          </a>
          <a href="https://ucards.uk" class="text-gray-600 hover:text-blue-600 transition-colors">
            uCards
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbItems} />
      <ArticleEnhancements
        title={title}
        description={description}
        slug={slug}
        lang={lang}
        date={date}
        updated={updated}
        category={category}
        faqs={faqs}
        schemaType={schemaType}
      />
      <article class="prose">
        <slot />
      </article>
      {faqs && faqs.length > 0 && (
        <FAQ faqs={faqs} lang={lang} />
      )}
      <CTASection
        title={cta?.title || (lang === 'en' ? 'Get Your Virtual Card in 2 Minutes' : '2 分钟获取你的虚拟卡')}
        subtitle={cta?.subtitle || (lang === 'en' ? 'No KYC required. Pay with USDT.' : '无需 KYC，支持 USDT 支付')}
        slug={slug}
      />
      {related && related.length > 0 && (
        <RelatedPosts slugs={related} lang={lang} />
      )}
    </main>

    <Footer />
  </body>
</html>
