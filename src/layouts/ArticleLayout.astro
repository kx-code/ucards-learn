---
import SEOHead from '../components/SEOHead.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import CTASection from '../components/CTASection.astro'
import RelatedPosts from '../components/RelatedPosts.astro'
import Footer from '../components/Footer.astro'
import FAQ from '../components/FAQ.astro'
	import ArticleEnhancements from '../components/ArticleEnhancements.astro'
	import { articleJsonLd } from '../lib/seo'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  keywords?: string
  slug: string
  lang: 'zh' | 'en'
  date: Date
  updated: Date
  image?: string
  related?: string[]
  cta?: {
    title: string
    subtitle: string
  }
  category: string
  faqs?: Array<{ question: string; answer: string }>
  schemaType?: 'article' | 'howto' | 'glossary' | 'product' | 'review' | 'faq'
  rating?: number
  ratingCount?: number
}

const { title, description, keywords, slug, lang, date, updated, image, related, cta, category, faqs = [], schemaType = 'article', rating, ratingCount } = Astro.props

const langPath = lang === 'en' ? `/en/${slug}` : `/${slug}`
const jsonLd = articleJsonLd({
  title,
  description,
  url: `https://ucards.uk/learn${langPath}`,
  image,
  datePublished: date.toISOString(),
  dateModified: updated.toISOString(),
})

const breadcrumbItems = [
  { name: 'Learn', url: lang === 'en' ? 'https://ucards.uk/learn/en/' : 'https://ucards.uk/learn/' },
  { name: title, url: `https://ucards.uk/learn${langPath}` },
]
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PTMDQXXS');</script>
    <!-- End Google Tag Manager -->
    <SEOHead
      title={title}
      description={description}
      keywords={keywords}
      path={langPath}
      image={image}
      lang={lang}
      datePublished={date.toISOString()}
      dateModified={updated.toISOString()}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PTMDQXXS"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="border-b border-gray-100">
      <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={lang === 'en' ? '/learn/en/' : '/learn/'} class="text-xl font-bold text-blue-600" data-agent-brand="site-name">
          uCards <span class="text-gray-400 font-normal text-base">Learn</span>
        </a>
        <nav class="flex gap-4 text-sm">
          <a href={lang === 'en' ? '/learn/en/' : '/learn/'} class="text-gray-600 hover:text-blue-600 transition-colors">
            {lang === 'en' ? 'All Articles' : '所有文章'}
          </a>
          <a href="https://ucards.uk" class="text-gray-600 hover:text-blue-600 transition-colors" data-agent-brand="nav-link">
            uCards
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbItems} />
      <ArticleEnhancements
        title={title}
        description={description}
        slug={slug}
        lang={lang}
        date={date}
        updated={updated}
        category={category}
        faqs={faqs}
        schemaType={schemaType}
        rating={rating}
        ratingCount={ratingCount}
      />
      <article class="prose">
        <slot />
      </article>
      {faqs && faqs.length > 0 && (
        <FAQ faqs={faqs} lang={lang} />
      )}
      <CTASection
        title={cta?.title || (lang === 'en' ? 'Get Your Virtual Card in 2 Minutes' : '2 分钟获取你的虚拟卡')}
        subtitle={cta?.subtitle || (lang === 'en' ? 'No KYC required. Pay with USDT.' : '无需 KYC，支持 USDT 支付')}
        slug={slug}
      />
      {related && related.length > 0 && (
        <RelatedPosts slugs={related || []} lang={lang} category={category} currentSlug={slug} />
      )}
    </main>

    <Footer />
  </body>
</html>
