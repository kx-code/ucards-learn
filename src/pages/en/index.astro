---
import { getCollection } from 'astro:content'
import SEOHead from '../../components/SEOHead.astro'
import Footer from '../../components/Footer.astro'
import { collectionJsonLd } from '../../lib/seo'
import '../../styles/global.css'

const articles = await getCollection('article', ({ id }) => id.startsWith('en/'))

const categories: Record<string, string> = {
  tutorial: 'Tutorials',
  'use-case': 'Use Cases',
  comparison: 'Comparisons',
  country: 'By Country',
  brand: 'By Brand',
  education: 'Crypto Education',
  resource: 'Resources',
}

const grouped = Object.entries(categories).reduce(
  (acc, [key, label]) => {
    const items = articles.filter((a) => a.data.category === key)
    if (items.length > 0) acc[key] = { label, items }
    return acc
  },
  {} as Record<string, { label: string; items: typeof articles }>,
)

const jsonLd = collectionJsonLd('uCards Learn', 'https://ucards.uk/learn/en/')
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PTMDQXXS');</script>
    <!-- End Google Tag Manager -->
    <SEOHead
      title="Learn Center"
      description="Complete guides on virtual credit cards and cryptocurrency payments. Learn how to pay with USDT, get cards without KYC, and more."
      keywords="virtual credit card, crypto payment, USDT, online payment, tutorial"
      path="/en/"
      lang="en"
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PTMDQXXS"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="border-b border-gray-100">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <span class="text-xl font-bold text-blue-600">
          uCards <span class="text-gray-400 font-normal text-base">Learn</span>
        </span>
        <nav class="flex gap-4 text-sm">
          <a href="/learn/" class="text-gray-600 hover:text-blue-600">中文</a>
          <a href="https://ucards.uk" class="text-gray-600 hover:text-blue-600">uCards</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <h1 class="text-3xl font-bold mb-2">Learn Center</h1>
      <p class="text-gray-600 mb-8">Complete guides on virtual credit cards and crypto payments</p>

      {Object.values(grouped).map(({ label, items }) => (
        <section class="mb-10">
          <h2 class="text-xl font-bold mb-4 text-gray-800">{label}</h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((article) => (
              <a
                href={`/learn/en/${article.data.slug}`}
                class="block p-4 border border-gray-200 rounded-lg hover:border-blue-300 hover:shadow-sm transition-all"
              >
                <h3 class="font-medium text-gray-900 mb-1">{article.data.title}</h3>
                <p class="text-sm text-gray-500 line-clamp-2">{article.data.description}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>

    <Footer />
  </body>
</html>
