---
import { getCollection, render } from 'astro:content'
import ArticleLayout from '../layouts/ArticleLayout.astro'
import { extractHowToSteps } from '../lib/seo'

export async function getStaticPaths() {
  const articles = await getCollection('article', ({ id }) => id.startsWith('zh/'))
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content, headings } = await render(article)
const howtoSteps = article.data.category === 'tutorial' ? extractHowToSteps(headings) : []
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  keywords={article.data.keywords}
  slug={article.data.slug}
  lang="zh"
  date={article.data.date}
  updated={article.data.updated}
  image={article.data.image}
  related={article.data.related}
  cta={article.data.cta}
  category={article.data.category}
  faqs={article.data.faqs}
  schemaType={article.data.schemaType}
  rating={article.data.rating}
  ratingCount={article.data.ratingCount}
  howtoSteps={howtoSteps}
>
  <Content />
</ArticleLayout>
