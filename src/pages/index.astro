---
import { getCollection } from 'astro:content'
import SEOHead from '../components/SEOHead.astro'
import Footer from '../components/Footer.astro'
import { collectionJsonLd } from '../lib/seo'
import '../styles/global.css'

const articles = await getCollection('article', ({ id }) => id.startsWith('zh/'))

const categories: Record<string, string> = {
  tutorial: '教程',
  'use-case': '使用场景',
  comparison: '对比评测',
  country: '国家/地区',
  brand: '品牌',
  education: '加密教育',
  resource: '资源',
}

const grouped = Object.entries(categories).reduce(
  (acc, [key, label]) => {
    const items = articles.filter((a) => a.data.category === key)
    if (items.length > 0) acc[key] = { label, items }
    return acc
  },
  {} as Record<string, { label: string; items: typeof articles }>,
)

const jsonLd = collectionJsonLd('uCards Learn', 'https://ucards.uk/learn/')
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="uCards Team" />
    <meta property="article:author" content="https://ucards.uk" />
    <meta property="article:published_time" content="2026-04-30" />
    <meta property="article:modified_time" content="2026-04-30" />
    <SEOHead
      title="学习中心"
      description="虚拟信用卡和加密货币支付完全指南。了解如何使用 USDT 在线支付、无需 KYC 开卡等。"
      keywords="虚拟信用卡, 加密货币支付, USDT, 在线支付, 教程"
      path="/"
      lang="zh"
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <header class="border-b border-gray-100">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <span class="text-xl font-bold text-blue-600">
          uCards <span class="text-gray-400 font-normal text-base">Learn</span>
        </span>
        <nav class="flex gap-4 text-sm">
          <a href="/learn/en/" class="text-gray-600 hover:text-blue-600">English</a>
          <a href="https://ucards.uk" class="text-gray-600 hover:text-blue-600">uCards</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <h1 class="text-3xl font-bold mb-2">学习中心</h1>
      <p class="text-gray-600 mb-8">虚拟信用卡和加密货币支付完全指南</p>

      {Object.values(grouped).map(({ label, items }) => (
        <section class="mb-10">
          <h2 class="text-xl font-bold mb-4 text-gray-800">{label}</h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((article) => (
              <a
                href={`/learn/${article.data.slug}`}
                class="block p-4 border border-gray-200 rounded-lg hover:border-blue-300 hover:shadow-sm transition-all"
              >
                <h3 class="font-medium text-gray-900 mb-1">{article.data.title}</h3>
                <p class="text-sm text-gray-500 line-clamp-2">{article.data.description}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>

    <Footer />
  </body>
</html>
