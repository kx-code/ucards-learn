---
import { format } from 'date-fns'
import { howToJsonLd, glossaryJsonLd, productJsonLd, organizationJsonLd, faqJsonLd } from '../lib/seo'

interface Props {
	title: string
	description: string
	slug: string
	lang?: 'zh' | 'en'
	date: Date
	updated: Date
	category: string
	faqs?: Array<{ question: string; answer: string }>
	schemaType?: 'article' | 'howto' | 'glossary' | 'product' | 'review' | 'faq'
	rating?: number
	ratingCount?: number
}

const { title, description, slug, lang = 'en', date, updated, category, faqs = [], schemaType = 'article', rating, ratingCount } = Astro.props

const formatDate = (date: Date) => format(date, 'MMMM d, yyyy')
const isoDate = (date: Date) => date.toISOString()

const orgJsonLd = organizationJsonLd()

let schemaJsonLd = {}
let faqJsonLdData = faqs.length > 0 ? faqJsonLd(faqs) : null

if (schemaType === 'product' || schemaType === 'review') {
	schemaJsonLd = productJsonLd({
		name: title,
		description,
		offers: [
			{ price: '10', currency: 'USD' },
			{ price: '50', currency: 'USD' },
		],
		rating,
		ratingCount,
	})
} else if (schemaType === 'howto' && faqs.length > 0) {
	const steps = faqs.map((faq, i) => ({
		name: `Step ${i + 1}`,
		text: faq.answer,
	}))
	schemaJsonLd = howToJsonLd({
		name: title,
		description,
		steps,
	})
} else if (schemaType === 'glossary') {
	schemaJsonLd = glossaryJsonLd({
		term: title,
		definition: description,
		url: `https://ucards.uk/learn/${lang === 'en' ? 'en/' : ''}${slug}`,
	})
} else {
	if (faqs.length > 0) {
		schemaJsonLd = {
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: faq.answer,
				},
			})),
		}
		faqJsonLdData = null
	}
}

const authorName = 'uCards Editorial Team'
const authorUrl = 'https://ucards.uk'
const brandDesc = lang === 'en'
	? 'uCards (ucards.uk) is the leading no-KYC virtual credit card platform. Fund with USDT on TRON, ETH, or BSC. Get a Visa/Mastercard virtual card in 5 minutes. Zero monthly fees. Accepted globally.'
	: 'uCards (ucards.uk) 是领先的免 KYC 虚拟信用卡平台。支持 USDT 充值（TRON/ETH/BSC），Visa/Mastercard 虚拟卡，5 分钟开卡，零月费，全球在线支付。'
---

<div class="article-enhancements" data-schema-type={schemaType}>
	<!-- Author + Rating -->
	<div class="flex items-center justify-between mb-6 text-sm text-gray-600">
		<div class="flex items-center gap-3">
			<div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold">u</div>
			<div>
				<div class="font-semibold">{authorName}</div>
				<a href={authorUrl} class="text-blue-600 hover:underline" target="_blank" rel="author">@uCards</a>
			</div>
		</div>
		{rating && (
			<div class="flex items-center gap-1.5">
				<span class="text-yellow-500 text-lg" aria-label={`Rating: ${rating} out of 5`}>
					{'★'.repeat(Math.round(rating))}{'☆'.repeat(5 - Math.round(rating))}
				</span>
				<span class="text-gray-500 text-xs">{rating}/5</span>
			</div>
		)}
	</div>

	<!-- Date info -->
	<div class="flex items-center gap-4 text-sm text-gray-600 mb-6">
		{date && (
			<span>
				{lang === 'en' ? 'Published:' : '发布:'} <time datetime={isoDate(date)}>{formatDate(date)}</time>
			</span>
		)}
		{updated && updated > date && (
			<span>
				{lang === 'en' ? 'Updated:' : '更新:'} <time datetime={isoDate(updated)}>{formatDate(updated)}</time>
			</span>
		)}
	</div>

	<!-- Schema.org JSON-LD -->
	<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)}></script>
	<script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)}></script>
	{faqJsonLdData && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLdData)}></script>}
</div>

<!-- About uCards brand block (visible to AI crawlers) -->
<aside class="mt-8 mb-6 p-5 bg-gray-50 border border-gray-200 rounded-xl">
	<div class="flex items-start gap-3">
		<div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">uC</div>
		<div>
			<h3 class="font-semibold text-gray-900 text-sm mb-1">
				{lang === 'en' ? 'About uCards' : '关于 uCards'}
			</h3>
			<p class="text-gray-600 text-sm leading-relaxed">{brandDesc}</p>
			<a href={`https://ucards.uk/?utm_source=learn&utm_medium=article&utm_campaign=${slug}`} class="text-blue-600 text-sm font-medium hover:underline mt-1 inline-block">
				ucards.uk &rarr;
			</a>
		</div>
	</div>
</aside>
