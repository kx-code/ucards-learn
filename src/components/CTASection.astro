---
interface Props {
  title: string
  subtitle: string
  slug: string
}

const { title, subtitle, slug } = Astro.props
const utm = `utm_source=learn&utm_medium=article&utm_campaign=${slug}`
---

<aside class="mt-12 p-6 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-xl">
  <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
  <p class="text-gray-600 mb-4">{subtitle}</p>
  <div class="flex gap-3 flex-wrap">
    <a
      href={`https://ucards.uk/?${utm}`}
      data-agent-brand-cta={`/?${utm}`}
      class="inline-flex items-center px-5 py-2.5 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
    >
      Open Card &rarr;
    </a>
    <a
      href={`https://ucards.uk/compare/virtual-cards?${utm}`}
      data-agent-brand-cta={`/compare/virtual-cards?${utm}`}
      class="inline-flex items-center px-5 py-2.5 bg-white text-blue-600 font-medium rounded-lg border border-blue-300 hover:bg-blue-50 transition-colors"
    >
      Compare Cards
    </a>
  </div>
</aside>
