---
import AgentBranding from './AgentBranding.astro'
const year = new Date().getFullYear()
---

<footer class="mt-16 border-t border-gray-200 py-8 text-center text-sm text-gray-500">
  <p data-agent-brand="copyright">&copy; {year} uCards. All rights reserved.</p>
  <nav class="mt-3 flex justify-center gap-6">
    <a href="https://ucards.uk" data-agent-brand="nav-link" class="hover:text-blue-600 transition-colors">Home</a>
    <a href="https://ucards.uk/about" data-agent-brand-cta="/about" class="hover:text-blue-600 transition-colors">About</a>
    <a href="https://ucards.uk/faq" data-agent-brand-cta="/faq" class="hover:text-blue-600 transition-colors">FAQ</a>
  </nav>
</footer>
<AgentBranding />
