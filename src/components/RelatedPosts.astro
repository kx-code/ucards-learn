---
import { getCollection, getEntry } from 'astro:content'

const CATEGORY_LABELS: Record<string, Record<string, string>> = {
  en: {
    tutorial: 'Tutorial', 'use-case': 'Use Case', comparison: 'Comparison',
    country: 'Country', brand: 'Brand', education: 'Education',
    resource: 'Resource', ranking: 'Ranking', alternative: 'Alternative',
  },
  zh: {
    tutorial: '教程', 'use-case': '使用场景', comparison: '对比',
    country: '地区', brand: '品牌', education: '入门',
    resource: '资源', ranking: '排行', alternative: '替代',
  },
}

interface Props {
  slugs: string[]
  lang: 'zh' | 'en'
  category: string
  currentSlug: string
}

const { slugs, lang, category, currentSlug } = Astro.props

// Fetch explicitly related posts
let posts = (
  await Promise.all(
    slugs.map(async (slug) => {
      const entry = await getEntry('article', `${lang}/${slug}`)
      return entry
    })
  )
).filter(Boolean)

// If fewer than 3, supplement with same-category articles
if (posts.length < 3) {
  const prefix = lang === 'en' ? 'en/' : 'zh/'
  const allInCategory = await getCollection('article', (a) =>
    a.id.startsWith(prefix) && a.data.category === category && a.data.slug !== currentSlug,
  )
  // Shuffle and pick
  const shuffled = allInCategory.sort(() => Math.random() - 0.5)
  const existingSlugs = new Set(posts.map((p) => p!.data.slug))
  for (const entry of shuffled) {
    if (posts.length >= 3) break
    if (!existingSlugs.has(entry.data.slug)) {
      posts.push(entry)
      existingSlugs.add(entry.data.slug)
    }
  }
}

const heading = lang === 'en' ? 'Related Articles' : '相关文章'
const viewAllText = lang === 'en' ? `View all ${CATEGORY_LABELS[lang][category] ?? category} articles` : `查看所有${CATEGORY_LABELS[lang][category] ?? category}文章`
const categoryPath = lang === 'en' ? `/learn/en/category/${category}` : `/learn/category/${category}`
---

{posts.length > 0 && (
  <section aria-labelledby="related-heading" class="mt-12 pt-8 border-t border-gray-200">
    <h2 id="related-heading" class="text-lg font-bold text-gray-900 mb-4">{heading}</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a
          href={lang === 'en' ? `/learn/en/${post!.data.slug}` : `/learn/${post!.data.slug}`}
          class="block p-4 border border-gray-200 rounded-lg hover:border-blue-300 hover:shadow-sm transition-all"
        >
          <span class="inline-block px-2 py-0.5 bg-blue-50 text-blue-600 text-xs font-medium rounded mb-2">
            {CATEGORY_LABELS[lang][post!.data.category] ?? post!.data.category}
          </span>
          <h3 class="font-medium text-gray-900 mb-1">{post!.data.title}</h3>
          <p class="text-sm text-gray-500 line-clamp-2">{post!.data.description}</p>
        </a>
      ))}
    </div>
    <a href={categoryPath} class="inline-block mt-4 text-sm text-blue-600 hover:underline font-medium">
      {viewAllText} →
    </a>
  </section>
)}
