---
import { getEntry } from 'astro:content'

interface Props {
  slugs: string[]
  lang: 'zh' | 'en'
}

const { slugs, lang } = Astro.props

const posts = (
  await Promise.all(
    slugs.map(async (slug) => {
      const entry = await getEntry('article', `${lang}/${slug}`)
      return entry
    })
  )
).filter(Boolean)
---

{posts.length > 0 && (
  <section class="mt-12 pt-8 border-t border-gray-200">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Related Articles</h3>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a
          href={lang === 'en' ? `/learn/en/${post!.data.slug}` : `/learn/${post!.data.slug}`}
          class="block p-4 border border-gray-200 rounded-lg hover:border-blue-300 hover:shadow-sm transition-all"
        >
          <h4 class="font-medium text-gray-900 mb-1">{post!.data.title}</h4>
          <p class="text-sm text-gray-500 line-clamp-2">{post!.data.description}</p>
        </a>
      ))}
    </div>
  </section>
)}
