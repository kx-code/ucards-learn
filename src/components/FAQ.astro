---
import { faqJsonLd } from '../lib/seo'

interface Props {
	faqs: Array<{
		question: string
		answer: string
	}>
	lang?: 'zh' | 'en'
}

const { faqs, lang = 'en' } = Astro.props

const faqTitle = lang === 'en' ? 'Frequently Asked Questions' : '常见问题'

---

<section class="my-12 bg-gray-50 rounded-lg p-8">
	<h2 id="faq" class="text-2xl font-bold mb-6">{faqTitle}</h2>
	<div class="space-y-4">
		{faqs.map((faq, index) => (
			<details class="group bg-white rounded-lg p-4 shadow-sm">
				<summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
					<span>{faq.question}</span>
					<span class="text-blue-600 transform group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<div class="mt-3 text-gray-600 prose prose-sm">
					{faq.answer}
				</div>
			</details>
		))}
	</div>
</section>

<script define:attributes={{ type: 'application/ld+json' }}>
	{JSON.stringify(faqJsonLd(faqs))}
</script>
<style>
	summary::-webkit-details-marker {
		display: none;
	}
</style>
